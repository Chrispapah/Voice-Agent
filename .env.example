# =============================================================================
# AI SDR - Railway Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# -- Supabase Postgres (use the pooler endpoint, port 6543) ------------------
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# -- Supabase Auth ------------------------------------------------------------
SUPABASE_URL=https://your-project-ref.supabase.co
# Keep SUPABASE_JWT_SECRET for HS256 projects or as a fallback.
# Newer Supabase projects may issue asymmetric tokens verified through JWKS.
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# -- LLM provider ------------------------------------------------------------
LLM_PROVIDER=openai          # openai | anthropic | groq | stub
LLM_MODEL_NAME=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# -- Speech-to-text (STT_PROVIDER=google | deepgram) ------------------------
STT_PROVIDER=google
# Google Cloud Speech-to-Text (API key; enable Speech API on the GCP project)
GOOGLE_SPEECH_API_KEY=
GOOGLE_SPEECH_LANGUAGE_CODE=en-US
GOOGLE_SPEECH_MODEL=phone_call
# After last interim, wait this many ms of silence before treating as final (lower = more aggressive; floor 40ms in app).
GOOGLE_UTTERANCE_SILENCE_MS=500
# Optional: set false so mic is not muted while bot speaks (can help barge-in; may increase echo).
GOOGLE_MUTE_DURING_SPEECH=true

# -- Deepgram STT (when STT_PROVIDER=deepgram) -------------------------------
DEEPGRAM_API_KEY=
# Optional tuning (defaults in config.py): e.g. DEEPGRAM_UTTERANCE_CUTOFF_MS=2000

# -- ElevenLabs TTS -----------------------------------------------------------
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# -- Twilio telephony ---------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -- Public URL for Twilio webhooks (Railway assigns this) --------------------
BASE_URL=https://your-app.up.railway.app

# -- Optional: Redis for cross-replica call config ----------------------------
# REDIS_URL=redis://...
